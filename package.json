{
  "name": "rice-mill-website",
  "version": "1.0.0",
  "description": "Multi-page rice mill website (frontend + backend)",
  "main": "app.js",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "tunnel": "node scripts/start-with-ngrok.js",
    "dev:tunnel": "node scripts/start-with-ngrok.js",
    "db:setup": "node scripts/setup-db.js",
    "db:seed": "node scripts/seed-db.js",
    "db:migrate:notifications:index": "node scripts/migrate-add-notifications-unique.js",
    "db:migrate:notifications:triggers": "node scripts/migrate-add-notifications-triggers.js",
    "db:migrate:status-history": "node scripts/migrate-add-status-history.js",
    "db:migrate:cancellation-resource-status": "node scripts/migrate-add-cancellation-resource-status.js",
    "db:cleanup:notifications": "node scripts/cleanup-notifications.js",
    "serve:static": "http-server public -p 3000 -c-1",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css",
    "watch:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch"
  },
  "keywords": [
    "rice",
    "mill",
    "milling",
    "website"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "localtunnel": "^2.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.5",
    "ngrok": "^4.3.3"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0"
  }
}
